  "license": "CC0-1.0",
  "packageManager": "yarn@4.13.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vscode-langservers-extracted": "^4.10.0"
  },
