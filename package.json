{
  "name": "obsidian-plugin-incremental-filenames",
  "version": "1.0.0",
  "description": "Use incremental filenames in Obsidian",
  "main": "main.ts",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
