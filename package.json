{
	"name": "obsidian-plugin-incremental-files",
	"version": "1.0.0",
	"description": "Folder-scoped incremental files for Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"types": "tsc -noEmit -skipLibCheck",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"author": "Teajey <21069848+Teajey@users.noreply.github.com>",
	"license": "CC0-1.0",
	"packageManager": "yarn@4.13.0",
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@eslint/js": "^9.30.1",
		"@eslint/json": "^1.1.0",
		"@types/node": "^25.5.0",
		"esbuild": "^0.27.4",
		"eslint": "^9.30.1",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vscode-langservers-extracted": "^4.10.0"
	},
	"dependencies": {
		"obsidian": "^1.12.3"
	}
